@cli.command("status")
@click.pass_context
def status_cmd(ctx):
    """Show backend info, secret count, and migration state."""
    be = ctx.obj["backend"]
    btype = type(be).__name__
    names = be.list()
    click.secho(f"Backend:  {btype}", fg="cyan", bold=True)
    click.secho(f"Secrets:  {len(names)}", fg="cyan")

    # Check ~/.secrets for comparison
    fb = FileBackend()
    file_names = fb.list()
    click.secho(f"\n~/.secrets: {len(file_names)} exports", fg="white")

    if isinstance(be, FileBackend):
        click.echo("\nUsing file backend — run `secrets migrate` to move to Keychain.")
        return

    # Compare
    in_backend = set(names)
    in_file = set(file_names)
    missing = in_file - in_backend
    extra = in_backend - in_file

    if missing:
        click.secho(f"\nIn ~/.secrets but NOT in {btype}: {len(missing)}", fg="yellow")
        for n in sorted(missing):
            click.echo(f"  {n}")
    if extra:
        click.secho(f"\nIn {btype} but NOT in ~/.secrets: {len(extra)}", fg="blue")
        for n in sorted(extra):
            click.echo(f"  {n}")
    if not missing and not extra:
        click.secho(f"\nFully synced.", fg="green")


@cli.command("migrate")
@click.option("--dry-run", is_flag=True, help="Show what would be migrated.")
@click.option("--source", type=click.Path(exists=True), default=str(DEFAULT_PATH),
              help="Source file (default: ~/.secrets).")
@click.pass_context
def migrate_cmd(ctx, dry_run, source):
    """Import all secrets from ~/.secrets into the active backend.

    \b
    Reads the source file, parses every `export KEY=VALUE` line,
    and writes each to the backend. Does not modify the source file.

    After migrating, verify with `secrets status`, then:
        chmod 000 ~/.secrets
        # Remove `source ~/.secrets` from .zshrc
    """
    be = ctx.obj["backend"]
    if isinstance(be, FileBackend):
        click.secho("Cannot migrate file → file. Use --backend keychain.", fg="red", err=True)
        sys.exit(1)

    fb = FileBackend(source)
    file_secrets = fb._parse()

    if not file_secrets:
        click.secho("No exports found in source file.", fg="yellow")
        return

    click.secho(f"Source:  {source} ({len(file_secrets)} exports)", fg="cyan")
    click.secho(f"Target:  {type(be).__name__}", fg="cyan")
    click.echo()

    added, updated, skipped = 0, 0, 0
    for name in sorted(file_secrets):
        value = file_secrets[name]
        existing = be.get(name)
        if existing == value:
            skipped += 1
            if not dry_run:
                continue
            click.echo(f"  skip  {name} (already present, same value)")
        elif existing is not None:
            updated += 1
            label = click.style("update", fg="cyan")
            click.echo(f"  {label} {name}")
            if not dry_run:
                be.set(name, value)
        else:
            added += 1
            label = click.style("add", fg="green")
            click.echo(f"  {label}    {name}")
            if not dry_run:
                be.set(name, value)

    click.echo()
    if dry_run:
        click.secho(f"Dry run: {added} to add, {updated} to update, {skipped} unchanged.", fg="cyan")
    else:
        click.secho(f"Migrated: {added} added, {updated} updated, {skipped} unchanged.", fg="green")
        click.echo()
        click.secho("Next steps:", fg="white", bold=True)
        click.echo("  1. Verify: secrets status")
        click.echo("  2. Lock:   chmod 000 ~/.secrets")
        click.echo("  3. Remove: `source ~/.secrets` from .zshrc")


