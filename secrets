#!/usr/bin/env python3
"""Manage secrets across backends: macOS Keychain, GCP Secret Manager, file.

Evolves the original ~/.secrets file manager into a multi-backend secret
store with cross-site sync. See platform/architecture/specs/credential-scoping.md.
"""

import difflib
import json
import os
import re
import shutil
import subprocess
import sys
from abc import ABC, abstractmethod
from datetime import datetime
from pathlib import Path

import click

DEFAULT_PATH = Path.home() / ".secrets"
SITE_CONFIG = Path.home() / ".config" / "haak" / "site.yaml"
KEYCHAIN_SERVICE = "haak"
GENERIC_HEADS = {"API", "SECRET", "DEFAULT", "MY", "THE", "APP", "DB"}
VALID_NAME = re.compile(r'^[A-Za-z_][A-Za-z0-9_]*$')
EXPORT_RE = re.compile(r'^export\s+([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*)')
BARE_RE = re.compile(r'^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*)')
UNSET_RE = re.compile(r'^unset\s+([A-Za-z_][A-Za-z0-9_]*)')


# ── Backends ────────────────────────────────────────────────────────

class SecretBackend(ABC):
    """Abstract secret storage backend."""

    @abstractmethod
    def get(self, name: str) -> str | None: ...

    @abstractmethod
    def set(self, name: str, value: str) -> None: ...

    @abstractmethod
    def delete(self, name: str) -> None: ...

    @abstractmethod
    def list(self) -> list[str]: ...

    def has(self, name: str) -> bool:
        return self.get(name) is not None


class KeychainBackend(SecretBackend):
    """macOS Keychain via `security` CLI."""

    def __init__(self, service: str = KEYCHAIN_SERVICE):
        self.service = service

    def get(self, name: str) -> str | None:
        r = subprocess.run(
            ["security", "find-generic-password", "-s", self.service,
             "-a", name, "-w"],
            capture_output=True, text=True, timeout=5,
        )
        return r.stdout.rstrip("\n") if r.returncode == 0 else None

    def set(self, name: str, value: str) -> None:
        # delete first to avoid "already exists" error
        subprocess.run(
            ["security", "delete-generic-password", "-s", self.service,
             "-a", name],
            capture_output=True, timeout=5,
        )
        subprocess.run(
            ["security", "add-generic-password", "-s", self.service,
             "-a", name, "-w", value, "-U"],
            capture_output=True, text=True, timeout=5, check=True,
        )

    def delete(self, name: str) -> None:
        subprocess.run(
            ["security", "delete-generic-password", "-s", self.service,
             "-a", name],
            capture_output=True, timeout=5,
        )

    def list(self) -> list[str]:
        r = subprocess.run(
            ["security", "dump-keychain"],
            capture_output=True, text=True, timeout=10,
        )
        names = []
        acct = None
        svce = None
        for line in r.stdout.splitlines():
            s = line.strip()
            m = re.search(r'"acct"<blob>="([^"]+)"', s)
            if m:
                acct = m.group(1)
            m = re.search(r'"svce"<blob>="([^"]+)"', s)
            if m:
                svce = m.group(1)
            # Also check the 0x00000007 format (service name)
            m = re.search(r'0x00000007 <blob>="([^"]+)"', s)
            if m:
                svce = m.group(1)
            if s.startswith("keychain:") or s == "":
                if acct and svce == self.service:
                    names.append(acct)
                acct = svce = None
        # Catch last entry
        if acct and svce == self.service:
            names.append(acct)
        return sorted(set(names))


class FileBackend(SecretBackend):
    """Reads/writes the legacy ~/.secrets shell file."""

    def __init__(self, path: str | Path = DEFAULT_PATH):
        self.path = Path(path).expanduser()

    def _parse(self) -> dict[str, str]:
        if not self.path.exists():
            return {}
        try:
            text = self.path.read_text()
        except PermissionError:
            return {}
        secrets = {}
        for line in text.splitlines():
            m = EXPORT_RE.match(line.strip())
            if m:
                val = m.group(2).strip()
                for q in ('"', "'"):
                    if val.startswith(q) and val.endswith(q):
                        val = val[1:-1]
                        break
                secrets[m.group(1)] = val
        return secrets

    def get(self, name: str) -> str | None:
        return self._parse().get(name)

    def set(self, name: str, value: str) -> None:
        text = self.path.read_text() if self.path.exists() else ""
        new_text, _ = set_export(text, name, value)
        write_with_backup(self.path, new_text)

    def delete(self, name: str) -> None:
        if not self.path.exists():
            return
        text = self.path.read_text()
        new_text, _ = remove_export(text, name)
        write_with_backup(self.path, new_text)

    def list(self) -> list[str]:
        return sorted(self._parse().keys())


class ExoscaleBackend(SecretBackend):
    """Exoscale S3-compatible object storage. One object per secret in a private bucket."""

    def __init__(self, bucket: str = "haak-secrets", prefix: str = "secrets/"):
        self.bucket = bucket
        self.prefix = prefix
        self._ensure_boto3()

    def _ensure_boto3(self):
        try:
            import boto3  # noqa: F401
        except ImportError:
            raise RuntimeError("boto3 required for Exoscale backend: pip install boto3")

    def _client(self):
        import boto3
        # Exoscale S3 endpoint — read creds from env or Keychain
        key_id = os.environ.get("AWS_ACCESS_KEY_ID") or KeychainBackend().get("AWS_ACCESS_KEY_ID") or ""
        secret = os.environ.get("AWS_SECRET_ACCESS_KEY") or KeychainBackend().get("AWS_SECRET_ACCESS_KEY") or ""
        return boto3.client("s3",
            endpoint_url="https://sos-ch-gva-2.exo.io",
            aws_access_key_id=key_id,
            aws_secret_access_key=secret,
        )

    def _key(self, name: str) -> str:
        return f"{self.prefix}{name}"

    def get(self, name: str) -> str | None:
        try:
            r = self._client().get_object(Bucket=self.bucket, Key=self._key(name))
            return r["Body"].read().decode()
        except Exception:
            return None

    def set(self, name: str, value: str) -> None:
        self._client().put_object(
            Bucket=self.bucket, Key=self._key(name),
            Body=value.encode(), ServerSideEncryption="AES256",
        )

    def delete(self, name: str) -> None:
        try:
            self._client().delete_object(Bucket=self.bucket, Key=self._key(name))
        except Exception:
            pass

    def list(self) -> list[str]:
        try:
            r = self._client().list_objects_v2(Bucket=self.bucket, Prefix=self.prefix)
            return sorted(obj["Key"][len(self.prefix):] for obj in r.get("Contents", []))
        except Exception:
            return []


class GCPSecretManagerBackend(SecretBackend):
    """Google Cloud Secret Manager. Requires google-cloud-secret-manager SDK."""

    def __init__(self, project: str = "cr-mainen"):
        self.project = project

    def _client(self):
        from google.cloud import secretmanager
        return secretmanager.SecretManagerServiceClient()

    def get(self, name: str) -> str | None:
        try:
            path = f"projects/{self.project}/secrets/{name}/versions/latest"
            r = self._client().access_secret_version(name=path)
            return r.payload.data.decode()
        except Exception:
            return None

    def set(self, name: str, value: str) -> None:
        client = self._client()
        parent = f"projects/{self.project}"
        secret_path = f"{parent}/secrets/{name}"
        # Create secret if it doesn't exist
        try:
            client.get_secret(name=secret_path)
        except Exception:
            client.create_secret(
                parent=parent,
                secret_id=name,
                secret={"replication": {"automatic": {}}},
            )
        # Add version
        client.add_secret_version(parent=secret_path, payload={"data": value.encode()})

    def delete(self, name: str) -> None:
        try:
            self._client().delete_secret(name=f"projects/{self.project}/secrets/{name}")
        except Exception:
            pass

    def list(self) -> list[str]:
        try:
            parent = f"projects/{self.project}"
            secrets = self._client().list_secrets(parent=parent)
            return sorted(s.name.split("/")[-1] for s in secrets)
        except Exception:
            return []


# Backend registry — all known backends by name.
_BACKEND_CLASSES = {
    "keychain": lambda: KeychainBackend(),
    "file": lambda: FileBackend(),
    "exoscale": lambda: ExoscaleBackend(),
    "gcp-secret-manager": lambda: GCPSecretManagerBackend(),
}


def get_backend(name: str | None = None) -> SecretBackend:
    """Resolve backend from explicit name, site config, or platform default."""
    if name is None:
        if SITE_CONFIG.exists():
            try:
                import yaml
                cfg = yaml.safe_load(SITE_CONFIG.read_text())
                name = cfg.get("site", {}).get("secret_backend", "file")
            except ImportError:
                name = _detect_platform()
        else:
            name = _detect_platform()

    factory = _BACKEND_CLASSES.get(name)
    if factory:
        return factory()
    click.secho(f"Unknown backend: {name}. Using file.", fg="yellow", err=True)
    return FileBackend()


def _detect_platform() -> str:
    if sys.platform == "darwin":
        return "keychain"
    return "file"


def _backends_for_scope(scope: str) -> list[tuple[str, SecretBackend]]:
    """Return the backends a secret with this scope should be written to.

    Always includes the local backend. Platform-scoped secrets also go to
    remote backends (Exoscale, GCP).
    """
    local = get_backend()
    backends = [("local", local)]
    if scope == "platform":
        # Platform secrets go to all infrastructure backends
        for name in ("exoscale", "gcp-secret-manager"):
            try:
                backends.append((name, _BACKEND_CLASSES[name]()))
            except Exception:
                pass  # SDK not installed — skip silently
    return backends


# ── Parsing (retained for file operations) ──────────────────────────

def parse_lines(text):
    for lineno, line in enumerate(text.splitlines(), 1):
        stripped = line.rstrip()
        if not stripped:
            yield ("blank", lineno)
        elif stripped.startswith("#"):
            yield ("comment", stripped, lineno)
        else:
            m = EXPORT_RE.match(stripped)
            if m:
                name, value = m.group(1), m.group(2)
                yield ("export", infer_prefix(name), name, value, stripped, lineno)
            else:
                yield ("other", stripped, lineno)


PREFIX_ALIASES = {
    "API_PORT": "SPECSFORM", "DATABASE": "SPECSFORM",
    "EMAIL": "SPECSFORM", "SKIP": "SPECSFORM",
    "SPECS": "SPECSFORM", "SUPERADMIN": "SPECSFORM",
    "USE": "SPECSFORM",
    "B2": "BACKBLAZE",
    "CLAUDE": "VERTEX",
    "CLOUD": "GOOGLE", "GCP": "GOOGLE",
    "HF": "HUGGINGFACE",
    "MAC": "SPECSFORM", "METADATA": "GOOGLE",
    "S3": "AWS",
}

def infer_prefix(name):
    parts = name.split("_")
    if len(parts) >= 2 and parts[0] in GENERIC_HEADS:
        head = "_".join(parts[:2])
    else:
        head = parts[0]
    return PREFIX_ALIASES.get(head, head)


# ── Linting ──────────────────────────────────────────────────────────

class Diagnostic:
    __slots__ = ("level", "line", "msg")

    def __init__(self, level, line, msg):
        self.level = level
        self.line = line
        self.msg = msg

    def __str__(self):
        tag = click.style(f"  {self.level}", fg="red" if self.level == "error" else "yellow")
        loc = click.style(f"L{self.line}", fg="white", bold=True)
        return f"{tag} {loc}: {self.msg}"


def lint(text):
    diags = []
    records = list(parse_lines(text))
    seen = {}
    for rec in records:
        if rec[0] == "export":
            _, _, name, value, _, lineno = rec
            seen.setdefault(name, []).append((value, lineno))
    for rec in records:
        if rec[0] == "other":
            _, raw, lineno = rec
            if lineno == 1 and raw.startswith("#!"):
                continue
            m = BARE_RE.match(raw)
            if m:
                diags.append(Diagnostic("warn", lineno,
                    f"bare assignment `{m.group(1)}=...` — missing `export`?"))
                continue
            if raw.startswith("export"):
                diags.append(Diagnostic("error", lineno,
                    f"malformed export: `{raw}`"))
                continue
            um = UNSET_RE.match(raw)
            if um:
                diags.append(Diagnostic("warn", lineno,
                    f"`unset {um.group(1)}` — intentional?"))
                continue
            if re.match(r'^(source |\.|\[|if |fi$|then$|else$|elif |for |done$|do$|case |esac$|eval )', raw):
                continue
            diags.append(Diagnostic("warn", lineno,
                f"unrecognised line: `{raw}`"))
        elif rec[0] == "export":
            _, _, name, value, raw, lineno = rec
            if re.search(r'\s+=', raw[len("export"):]) or re.search(r'=\s', raw):
                m_eq = re.match(r'^export\s+\S+(\s+)=', raw)
                if m_eq:
                    diags.append(Diagnostic("error", lineno,
                        f"`{name}`: space before `=` — shell will not assign"))
                m_eq2 = re.match(r'^export\s+\S+=(\s+)', raw)
                if m_eq2:
                    diags.append(Diagnostic("error", lineno,
                        f"`{name}`: space after `=` — shell will not assign"))
            for q in ('"', "'"):
                if value.count(q) % 2 != 0:
                    diags.append(Diagnostic("error", lineno,
                        f"`{name}`: unmatched {q} in value"))
            if " " in value and not (value.startswith('"') or value.startswith("'")):
                if not re.match(r'^\$[\({]', value):
                    diags.append(Diagnostic("warn", lineno,
                        f"`{name}`: unquoted value contains spaces"))
            if value in ('', '""', "''"):
                diags.append(Diagnostic("warn", lineno,
                    f"`{name}`: empty value"))
    for name, occurrences in seen.items():
        if len(occurrences) < 2:
            continue
        values = set(v for v, _ in occurrences)
        lines = [ln for _, ln in occurrences]
        if len(values) > 1:
            diags.append(Diagnostic("error", lines[-1],
                f"`{name}`: conflicting values on lines {', '.join(map(str, lines))}"))
        else:
            diags.append(Diagnostic("warn", lines[-1],
                f"`{name}`: duplicate export on lines {', '.join(map(str, lines))}"))
    diags.sort(key=lambda d: d.line)
    return diags


# ── Grouping ─────────────────────────────────────────────────────────

def group_exports(records):
    all_records = list(records)
    last_index = {}
    for i, rec in enumerate(all_records):
        if rec[0] == "export":
            last_index[rec[2]] = i
    dupes = 0
    deduped = []
    for i, rec in enumerate(all_records):
        if rec[0] == "export" and last_index[rec[2]] != i:
            dupes += 1
            continue
        deduped.append(rec)
    groups = []
    comments, exports, prefix = [], [], None
    def flush():
        nonlocal comments, exports, prefix
        if exports or comments:
            groups.append({"comments": comments, "exports": exports, "prefix": prefix})
        comments, exports, prefix = [], [], None
    for rec in deduped:
        if rec[0] == "blank":
            flush()
        elif rec[0] == "comment":
            if exports:
                flush()
            comments.append(rec[1])
        elif rec[0] == "export":
            p = rec[1]
            if prefix is not None and p != prefix:
                flush()
            prefix = p
            exports.append(rec)
        elif rec[0] == "other":
            flush()
            groups.append({"other": rec[1]})
    flush()
    return groups, dupes


# ── Sorting ──────────────────────────────────────────────────────────

def sort_and_merge(groups):
    header, export_groups, other = [], [], []
    for g in groups:
        if "other" in g:
            other.append(g)
        elif not g.get("exports"):
            if not export_groups:
                header.append(g)
        else:
            export_groups.append(g)
    export_groups.sort(key=lambda g: (g.get("prefix") or "zzz").lower())
    merged = []
    for g in export_groups:
        if merged and merged[-1].get("prefix") == g.get("prefix"):
            prev = merged[-1]
            for c in g.get("comments", []):
                if c not in prev["comments"] and not _is_section_header(c):
                    prev["comments"].append(c)
            prev["exports"].extend(g["exports"])
        else:
            merged.append(g)
    return header + merged + other


_SEPARATOR_RE = re.compile(r'^#\s*[=\-─━]+\s*$')

def _is_section_header(line):
    s = line.strip()
    return s == '#' or bool(_SEPARATOR_RE.match(s))


# ── Rendering ────────────────────────────────────────────────────────

def _extract_descriptive_comments(comments):
    out = []
    for c in comments:
        if _is_section_header(c):
            continue
        text = c.lstrip("# ").strip()
        if text and (" " in text or any(p in text for p in "—-:()@")):
            out.append(c)
    return out


def render_group(group):
    if "other" in group:
        return [group["other"]]
    exports = sorted(group.get("exports", []), key=lambda r: r[2])
    if not exports:
        return list(group.get("comments", []))
    prefix = group.get("prefix", "")
    lines = [f"# {prefix}"]
    desc = _extract_descriptive_comments(group.get("comments", []))
    lines.extend(desc)
    for rec in exports:
        name, value = rec[2], rec[3]
        lines.append(f"export {name}={value}")
    return lines


def render_all(groups):
    blocks = ["\n".join(render_group(g)) for g in groups if render_group(g)]
    return "\n\n".join(blocks) + "\n"


# ── Mutation helpers ─────────────────────────────────────────────────

def write_with_backup(path, content):
    if not path.exists():
        path.write_text(content)
        os.chmod(str(path), 0o600)
        return None
    ts = datetime.now().strftime("%Y%m%d-%H%M%S")
    backup = path.with_suffix(f".{ts}.bak")
    shutil.copy2(path, backup)
    os.chmod(str(backup), 0o600)
    path.write_text(content)
    os.chmod(str(path), 0o600)
    return backup


def set_export(text, name, value, quote=True):
    if quote and not (value.startswith('"') or value.startswith("'")):
        value = f'"{value}"'
    new_line = f"export {name}={value}"
    lines = text.splitlines()
    last_idx = None
    for i, line in enumerate(lines):
        m = EXPORT_RE.match(line.strip())
        if m and m.group(1) == name:
            last_idx = i
    if last_idx is not None:
        lines[last_idx] = new_line
        return "\n".join(lines) + "\n", "updated"
    prefix = infer_prefix(name)
    insert_after = None
    for i, line in enumerate(lines):
        m = EXPORT_RE.match(line.strip())
        if m and infer_prefix(m.group(1)) == prefix:
            insert_after = i
    if insert_after is not None:
        lines.insert(insert_after + 1, new_line)
    else:
        if lines and lines[-1].strip():
            lines.append("")
        lines.append(new_line)
    return "\n".join(lines) + "\n", "added"


def remove_export(text, name):
    lines = text.splitlines()
    kept, removed = [], 0
    for line in lines:
        s = line.strip()
        m = EXPORT_RE.match(s) or BARE_RE.match(s) or UNSET_RE.match(s)
        if m and m.group(1) == name:
            removed += 1
            continue
        kept.append(line)
    return "\n".join(kept) + "\n", removed


# ── Stats ────────────────────────────────────────────────────────────

def count_exports(text):
    return len(re.findall(r'^export\s+', text, re.MULTILINE))


def stat_line(orig, result, dupes, n_groups):
    parts = [f"{count_exports(result)} exports"]
    if dupes:
        parts.append(f"{dupes} duplicates removed")
    parts.append(f"{n_groups} groups")
    return ", ".join(parts)


def build_context(path, do_sort):
    original = path.read_text()
    groups, dupes = group_exports(parse_lines(original))
    if do_sort:
        groups = sort_and_merge(groups)
    result = render_all(groups)
    n_groups = sum(1 for g in groups if g.get("exports"))
    return dict(path=path, original=original, result=result,
                groups=groups, dupes=dupes, n_groups=n_groups,
                sort=do_sort)


# ── CLI ──────────────────────────────────────────────────────────────

@click.group(invoke_without_command=True)
@click.option("--file", "-f", default=str(DEFAULT_PATH),
              help="Secrets file (for file backend and legacy commands).")
@click.option("--sort/--no-sort", default=True, help="Sort groups by prefix.")
@click.option("--backend", "-b", type=click.Choice(["keychain", "file", "auto"]),
              default="auto", help="Secret backend (default: auto-detect).")
@click.pass_context
def cli(ctx, file, sort, backend):
    """Manage secrets across backends.

    \b
    Backends:
        keychain     macOS Keychain (default on Mac)
        file         ~/.secrets shell file (legacy / Linux fallback)
        auto         detect from platform or site.yaml

    \b
    Core commands (backend-aware):
        secrets add KEY "value"      add or update a secret
        secrets rm KEY               remove a secret
        secrets get KEY              retrieve a secret value
        secrets list                 list all secret names
        secrets grep PATTERN         search by name substring

    \b
    Migration:
        secrets migrate              import ~/.secrets into Keychain
        secrets status               show backend info and secret count

    \b
    File-only commands (legacy):
        secrets diff / fix / lint / check / dupes / swap
    """
    ctx.ensure_object(dict)
    ctx.obj["path"] = Path(file)
    ctx.obj["sort"] = sort
    b = None if backend == "auto" else backend
    ctx.obj["backend"] = get_backend(b)
    ctx.obj["backend_name"] = backend

    if ctx.invoked_subcommand is None:
        # Default: show backend status
        be = ctx.obj["backend"]
        names = be.list()
        btype = type(be).__name__
        click.secho(f"Backend: {btype}", fg="cyan", bold=True)
        click.secho(f"Secrets: {len(names)}", fg="cyan")
        if names:
            click.echo()
            for n in names:
                click.echo(f"  {n}")
        click.echo()
        click.secho("Run `secrets add KEY VALUE` to add, `secrets migrate` to import from ~/.secrets", fg="cyan")


# ── Backend-aware commands ───────────────────────────────────────────

def _haak_root() -> Path:
    return Path(os.environ.get("HAAK_ROOT", str(Path.home() / "Projects" / "haak")))


def _registry_path() -> Path:
    return _haak_root() / "infra" / "config" / "credentials.yaml"


def _upsert_registry(var_name: str, group: str, scope: str) -> str:
    """Add a var to a credential group in the registry. Creates group if needed.

    Returns 'created_group', 'added_var', 'exists', or 'no_registry'.
    """
    reg_path = _registry_path()
    if not reg_path.exists():
        return "no_registry"

    import yaml

    text = reg_path.read_text()
    registry = yaml.safe_load(text) or {}
    creds = registry.setdefault("credentials", {})

    if group in creds:
        env = creds[group].setdefault("env", {})
        if var_name in env:
            return "exists"
        env[var_name] = "vault"
        # Rewrite just the env block to preserve formatting as much as possible
        reg_path.write_text(yaml.dump(registry, default_flow_style=False, sort_keys=False))
        return "added_var"
    else:
        creds[group] = {
            "scope": scope,
            "note": f"Added via secrets add --group {group}",
            "env": {var_name: "vault"},
            "consumers": ["unknown"],
        }
        reg_path.write_text(yaml.dump(registry, default_flow_style=False, sort_keys=False))
        return "created_group"


def _add_credential_to_mandate(agent: str, group: str) -> str:
    """Add a credential group to an agent mandate. Returns status string."""
    mandate_link = _haak_root() / ".claude" / "agents" / f"{agent}.md"
    if not mandate_link.exists():
        return f"mandate not found: {agent}"

    target = mandate_link.resolve()
    text = target.read_text()
    if not text.startswith("---"):
        return "no frontmatter"

    try:
        end = text.index("---", 3)
    except ValueError:
        return "malformed frontmatter"

    import yaml
    fm = yaml.safe_load(text[3:end]) or {}
    existing = fm.get("credentials", [])

    if group in existing:
        return "already present"

    existing.append(group)
    fm["credentials"] = existing

    # Rebuild the file: new frontmatter + original body
    body = text[end + 3:]
    new_fm = yaml.dump(fm, default_flow_style=False, sort_keys=False).rstrip()
    target.write_text(f"---\n{new_fm}\n---{body}")
    return "added"


@cli.command("add")
@click.argument("name")
@click.argument("value")
@click.option("--group", "-g", default="", help="Credential group in registry (e.g. 'telegram').")
@click.option("--scope", "-s", default="user", help="Scope for new groups: platform, org:<name>, project:<name>, user.")
@click.option("--agent", "-a", multiple=True, help="Agent(s) to grant access (adds group to mandate). Repeatable.")
@click.pass_context
def add_cmd(ctx, name, value, group, scope, agent):
    """Add or update a secret. Scope determines which backends receive it.

    \b
    Simple (local backend only):
        secrets add OPENAI_API_KEY sk-abc123

    \b
    Full lifecycle (all backends for scope + registry + mandate):
        secrets add NEW_TOKEN "abc" --group new-svc --scope platform --agent duta

    \b
    Add to existing group (inherits scope from registry):
        secrets add EXTRA_VAR "val" --group telegram
    """
    if not VALID_NAME.match(name):
        click.secho(f"Invalid variable name: {name}", fg="red", err=True)
        sys.exit(1)

    # Resolve effective scope: from --scope flag, or from existing group in registry
    effective_scope = scope
    if group and scope == "user":
        # Check if group already exists in registry with a different scope
        registry = _load_registry()
        existing = registry.get("credentials", {}).get(group, {})
        if existing and existing.get("scope"):
            effective_scope = existing["scope"]

    # 1. Write to all backends this scope requires
    backends = _backends_for_scope(effective_scope)
    for bname, be in backends:
        try:
            existed = be.has(name)
            be.set(name, value)
            action = "Updated" if existed else "Added"
            click.secho(f"{action}: {name} → {bname}", fg="green")
        except Exception as e:
            click.secho(f"Failed: {name} → {bname} ({e})", fg="red")

    # 2. Update registry if --group given
    if group:
        result = _upsert_registry(name, group, effective_scope)
        if result == "created_group":
            click.secho(f"Registry: created group '{group}' (scope: {effective_scope})", fg="cyan")
        elif result == "added_var":
            click.secho(f"Registry: added {name} to group '{group}'", fg="cyan")
        elif result == "exists":
            click.secho(f"Registry: {name} already in group '{group}'", fg="white")
        elif result == "no_registry":
            click.secho("Registry: credentials.yaml not found — skipped", fg="yellow")

    # 3. Update agent mandates if --agent given
    for ag in agent:
        if not group:
            click.secho(f"Mandate: --agent requires --group (skipping {ag})", fg="yellow")
            break
        result = _add_credential_to_mandate(ag, group)
        if result == "added":
            click.secho(f"Mandate: granted '{group}' to {ag}", fg="cyan")
        elif result == "already present":
            click.secho(f"Mandate: {ag} already has '{group}'", fg="white")
        else:
            click.secho(f"Mandate: {ag} — {result}", fg="yellow")


