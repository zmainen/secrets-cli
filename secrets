def _load_registry() -> dict:
    """Load credential registry from HAAK repo."""
    haak_root = os.environ.get("HAAK_ROOT", str(Path.home() / "Projects" / "haak"))
    reg = Path(haak_root) / "infra" / "config" / "credentials.yaml"
    if not reg.exists():
        return {}
    try:
        import yaml
        return yaml.safe_load(reg.read_text()) or {}
    except ImportError:
        click.secho("PyYAML not installed — needed for registry commands.", fg="red", err=True)
        sys.exit(1)


def _registry_secrets_for_site(registry: dict, site: str) -> dict[str, list[str]]:
    """Return {group_name: [var_names]} that a site needs."""
    creds = registry.get("credentials", {})
    result = {}
    for group_name, group in creds.items():
        scope = group.get("scope", "")
        # Platform secrets go to all sites
        if scope == "platform":
            result[group_name] = list(group.get("env", {}).keys())
        # Other scopes: check if site is explicitly listed (future)
        # For now, platform → all, everything else → mac-only
    return result


@cli.command("push")
@click.argument("name")
@click.option("--site", required=True, help="Target site (e.g. vm-platform).")
@click.option("--host", default="", help="SSH host (default: derived from site name).")
@click.option("--dry-run", is_flag=True)
@click.pass_context
def push_cmd(ctx, name, site, host, dry_run):
    """Push a single secret to a remote site via SSH.

    Reads the secret from the local backend and writes it to the remote
    site's backend (file-based: appends to ~/.secrets on the remote host).

    \b
    Examples:
        secrets push TELEGRAM_BOT_TOKEN --site vm-platform
        secrets push GITHUB_PAT --site vm-platform --host haak@194.182.180.219
    """
    be = ctx.obj["backend"]
    value = be.get(name)
    if value is None:
        click.secho(f"Not found locally: {name}", fg="red", err=True)
        sys.exit(1)

    # Resolve host
    if not host:
        site_hosts = {
            "vm-platform": "haak-exoscale",
            "haak-personal": "haak-exoscale",
        }
        host = site_hosts.get(site, site)

    if dry_run:
        click.echo(f"Would push {name} → {host}")
        return

    # Write to remote ~/.secrets via SSH
    # Use a heredoc to avoid shell escaping issues with the value
    import subprocess
    escaped = value.replace("'", "'\\''")
    cmd = f"ssh -o ConnectTimeout=10 {host} \"grep -q '^export {name}=' ~/.secrets 2>/dev/null && sed -i 's|^export {name}=.*|export {name}='\\'{escaped}\\''|' ~/.secrets || echo 'export {name}='\\'{escaped}\\'' >> ~/.secrets\""
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)
    if result.returncode != 0:
        click.secho(f"Failed: {result.stderr.strip()}", fg="red", err=True)
        sys.exit(1)
    click.secho(f"Pushed: {name} → {host}", fg="green")


@cli.command("sync")
@click.option("--site", default="", help="Target site (default: all sites).")
@click.option("--dry-run", is_flag=True)
@click.pass_context
def sync_cmd(ctx, site, dry_run):
    """Push all platform secrets to remote sites per credential registry.

    Reads the registry to determine which secrets each site needs,
    then pushes missing or changed secrets from the local backend.

    \b
    Examples:
        secrets sync                    # push to all sites
        secrets sync --site vm-platform # push to one site
        secrets sync --dry-run          # show what would be pushed
    """
    registry = _load_registry()
    creds = registry.get("credentials", {})
    if not creds:
        click.secho("No credential registry found. Create infra/config/credentials.yaml first.", fg="red", err=True)
        sys.exit(1)

    be = ctx.obj["backend"]

    # Collect platform secrets that need syncing
    platform_vars = {}
    for group_name, group in creds.items():
        if group.get("scope", "") != "platform":
            continue
        for var, val in group.get("env", {}).items():
            if val == "vault":
                secret = be.get(var)
                if secret:
                    platform_vars[var] = secret

    if not platform_vars:
        click.secho("No platform secrets found in local backend.", fg="yellow")
        return

    sites = {"vm-platform": "haak-exoscale"}
    if site:
        if site not in sites:
            click.secho(f"Unknown site: {site}. Known: {', '.join(sites)}", fg="red", err=True)
            sys.exit(1)
        sites = {site: sites[site]}

    for site_name, host in sites.items():
        click.secho(f"\n{site_name} ({host}):", fg="cyan", bold=True)
        pushed, skipped, failed = 0, 0, 0
        for var in sorted(platform_vars):
            if dry_run:
                click.echo(f"  push  {var}")
                pushed += 1
                continue
            try:
                import subprocess
                value = platform_vars[var]
                escaped = value.replace("'", "'\\''")
                cmd = f"ssh -o ConnectTimeout=10 -o BatchMode=yes {host} \"grep -q '^export {var}=' ~/.secrets 2>/dev/null && sed -i 's|^export {var}=.*|export {var}='\\'{escaped}\\''|' ~/.secrets || echo 'export {var}='\\'{escaped}\\'' >> ~/.secrets\""
                result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)
                if result.returncode == 0:
                    click.echo(f"  push  {var}")
                    pushed += 1
                else:
                    click.secho(f"  FAIL  {var}: {result.stderr.strip()}", fg="red")
                    failed += 1
            except Exception as e:
                click.secho(f"  FAIL  {var}: {e}", fg="red")
                failed += 1

        if dry_run:
            click.secho(f"  Dry run: {pushed} secrets to push", fg="cyan")
        else:
            click.secho(f"  Done: {pushed} pushed, {failed} failed", fg="green" if not failed else "yellow")


